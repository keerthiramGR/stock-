# =========================================================================
# Client Configuration (React Vite App)
# Place these in /client/.env
# =========================================================================
VITE_SUPABASE_URL=https://your-supabase-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-client-anon-key

# =========================================================================
# Server Configuration (Express API Engine)
# Place these in /server/.env
# =========================================================================
PORT=5000
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-never-expose-on-client
SUPABASE_ANON_KEY=your-supabase-client-anon-key
